@inherits LayoutComponentBase

@using Radzen
@using Radzen.Blazor
@using Microsoft.AspNetCore.Components.Authorization
@using Sport_Slot_booking_system.Web.Services

@inject AuthService AuthService
@inject CustomAuthStateProvider AuthProvider
@inject NavigationManager Nav

<RadzenLayout Style="height: 100vh">

    <!-- HEADER -->
    <RadzenHeader Style="background:#1976d2; color:white; padding:10px">
        <RadzenButton Icon="menu"
                      ButtonStyle="ButtonStyle.Light"
                      Size="ButtonSize.Small"
                      Click="@ToggleSidebar"
                      Style="margin-right:10px" />
        <h3>Sport Slot Booking System</h3>
    </RadzenHeader>

    <!-- SIDEBAR -->
    <RadzenSidebar @bind-Expanded="@sidebarExpanded" Style="background:#f4f4f4;">

        <RadzenPanelMenu>

            <!-- 🔐 AUTH BASED MENU -->
            <AuthorizeView>

                <!-- ✅ Logged IN -->
                <Authorized>
                    <RadzenPanelMenuItem Text="Dashboard" Icon="dashboard" Path="/dashboard" />
                    <RadzenPanelMenuItem Text="Users" Icon="people" Path="/users" />
                    <RadzenPanelMenuItem Text="Book Slot" Icon="event" Path="/slot-booking" />
                    <RadzenPanelMenuItem Text="My Bookings" Icon="list" Path="/my-bookings" />
                    <RadzenPanelMenuItem Text="Profile" Icon="account_circle" Path="/profile" />
                    <RadzenPanelMenuItem Text="Logout"
                                         Icon="logout"
                                         Click="@OnLogout"
                                         Disabled="@isLoggingOut" />
                </Authorized>

                <!-- ❌ NOT Logged IN -->
                <NotAuthorized>
                    <RadzenPanelMenuItem Text="Login" Icon="login" Path="/login" />
                    <RadzenPanelMenuItem Text="Register" Icon="person_add" Path="/register" />
                </NotAuthorized>

            </AuthorizeView>

        </RadzenPanelMenu>

    </RadzenSidebar>

    <!-- NOTIFICATION -->
    <RadzenNotification />
    @if (isLoggingOut)
    {
        <div style="
                position:fixed;
                top:0;
                left:0;
                width:100%;
                height:100%;
                background:rgba(0,0,0,0.3);
                display:flex;
                align-items:center;
                justify-content:center;
                z-index:9999;
            ">
            <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" Style="width:200px;" />
        </div>
    }
    <!-- BODY -->
    <RadzenBody Style="padding:20px">
        @Body
    </RadzenBody>

    <!-- FOOTER -->
    <RadzenFooter Style="background:#eee; padding:10px; text-align:center">
        © 2026 Sport Slot Booking System
    </RadzenFooter>

</RadzenLayout>

@code {
    bool sidebarExpanded = true;
    bool isLoggingOut = false;

    void ToggleSidebar()
    {
        sidebarExpanded = !sidebarExpanded;
    }

    async Task OnLogout()
    {
        try
        {
            isLoggingOut = true;

            await AuthService.Logout();

            AuthProvider.NotifyUserLogout();

            Nav.NavigateTo("/login", true);
        }
        catch
        {

        }
        finally
        {
            isLoggingOut = false;
        }
    }
}